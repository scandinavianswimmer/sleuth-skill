{
  "type": "object",
  "required": ["id", "title", "type", "severity", "repro", "evidence"],
  "properties": {
    "id": { "type": "string" },
    "title": { "type": "string" },
    "type": { "type": "string", "enum": ["bug", "security", "ux-friction", "design", "expected"] },
    "severity": { "type": "string", "enum": ["critical", "high", "medium", "low", "info"] },
    "route": { "type": "string" },
    "flow": { "type": "string" },
    "persona": { "type": "string" },
    "cwe": { "type": "string" },
    "pillar": { "type": "string", "enum": ["ai-slop", "typography", "color-contrast", "layout", "accessibility", "design-system", "motion", "performance"] },
    "wcag": { "type": "string" },
    "selector": { "type": "string" },
    "repro": { "type": "array", "items": { "type": "string" } },
    "evidence": { "type": "array", "items": { "type": "string" } },
    "suggestedFix": { "type": "string" },
    "codingAgentPrompt": { "type": "string" },
    "visibility": { "type": "string", "enum": ["user-visible", "hidden"] }
  }
}
